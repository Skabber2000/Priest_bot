# Cloudflare Worker secrets (set via `wrangler secret put` or .dev.vars for local)
ANTHROPIC_API_KEY=sk-ant-...
# Optional: Cloudflare Turnstile secret for abuse control. Leave blank to disable.
TURNSTILE_SECRET=

# Frontend build-time (set in web/.env.local)
VITE_WORKER_URL=http://localhost:8787
# Optional: Turnstile site key. Leave blank to disable the widget.
VITE_TURNSTILE_SITE_KEY=
